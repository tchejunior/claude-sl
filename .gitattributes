# Default: let Git auto-detect text vs binary
* text=auto

# Force LF for shell scripts, Python, JS/TS, JSON, YAML, Markdown
*.sh         text eol=lf
*.bash       text eol=lf
*.py         text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.md         text eol=lf
*.html       text eol=lf
*.css        text eol=lf

# Force CRLF for PowerShell (Windows-native)
*.ps1        text eol=crlf

# Binary
*.png        binary
*.jpg        binary
*.svg        text eol=lf
